local function CreateNumberInput(name, text, size, position, parent, fontSize, minVal, maxVal, getValue, setValue, formatText)
    local box = Instance.new("TextBox")
    box.Name = name
    box.Size = size
    box.Position = position
    box.Text = text
    box.TextColor3 = Color3.new(1, 1, 1)
    box.BackgroundTransparency = 1
    box.TextSize = fontSize or 16
    box.Font = Enum.Font.FredokaOne
    box.ClearTextOnFocus = false
    box.TextEditable = true
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(60, 60, 60)
    stroke.Thickness = 1.5
    stroke.Parent = box
    box.Parent = parent
    box.FocusLost:Connect(function()
        local numStr = box.Text:match("(%d+%.?%d*)")
        if numStr then
            local num = tonumber(numStr)
            if num then
                num = math.floor(num)
                num = math.clamp(num, minVal, maxVal)
                setValue(num)
                box.Text = formatText(num)
                return
            end
        end
        box.Text = formatText(getValue())
    end)
    return box
end

local function CreateMarshmallowButton(name, text, size, position, parent, textColor)
