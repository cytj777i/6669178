    panel.BackgroundTransparency = 0.5
    panel.BorderSizePixel = 0
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 20)
    corner.Parent = panel
end

local function GlobalIsPlayerPart(part)
    if not part.Parent then return false end
    if part.Parent == LocalPlayer.Character then return true end
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Character and part:IsDescendantOf(player.Character) then
            return true
        end
    end
    if part.Parent:FindFirstChild("Humanoid") or part.Parent:FindFirstChild("Head") then
        return true
    end
    return false
end

local function GlobalCalculateMoveDirection()
    local camera = Workspace.CurrentCamera
    if not camera then return Vector3.new(0, 0, 0) end
    if _G.globalMoveDirectionType == "up" then
        return Vector3.new(0, 1, 0)
    elseif _G.globalMoveDirectionType == "down" then
        return Vector3.new(0, -1, 0)
    elseif _G.globalMoveDirectionType == "forward" then
        local lookVector = camera.CFrame.LookVector
        return Vector3.new(lookVector.X, 0, lookVector.Z).Unit
    elseif _G.globalMoveDirectionType == "backward" then
        local lookVector = camera.CFrame.LookVector
        return -Vector3.new(lookVector.X, 0, lookVector.Z).Unit
    elseif _G.globalMoveDirectionType == "left" then
        local rightVector = camera.CFrame.RightVector
        return -Vector3.new(rightVector.X, 0, rightVector.Z).Unit
    elseif _G.globalMoveDirectionType == "right" then
        local rightVector = camera.CFrame.RightVector
        return Vector3.new(rightVector.X, 0, rightVector.Z).Unit
    else
        return Vector3.new(0, 0, 0)
    end
end

local function GlobalProcessPart(v)
    if GlobalIsPlayerPart(v) then return end
    if v:IsA("Part") and not v.Anchored then
        if _G.globalProcessedParts[v] then
            local existingBV = _G.globalProcessedParts[v].bodyVelocity
            local existingBG = _G.globalProcessedParts[v].bodyGyro
            if existingBV and existingBV.Parent then
                if _G.globalMoveDirectionType then
                    local finalVelocity = GlobalCalculateMoveDirection() * _G.globalFloatSpeed
                    existingBV.Velocity = finalVelocity
                else
                    existingBV.Velocity = Vector3.new(0, 0, 0)
                end
                if _G.globalFixedMode then
                    if not existingBG or not existingBG.Parent then
                        local bodyGyro = Instance.new("BodyGyro")
                        bodyGyro.Parent = v
                        bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                        bodyGyro.P = 1000
                        bodyGyro.D = 100
                        bodyGyro.CFrame = v.CFrame
                        _G.globalProcessedParts[v].bodyGyro = bodyGyro
                    end
                else
                    if existingBG and existingBG.Parent then
                        existingBG:Destroy()
                        _G.globalProcessedParts[v].bodyGyro = nil
                    end
                end
                return
            else
                _G.globalProcessedParts[v] = nil
            end
        end
        for _, x in ipairs(v:GetChildren()) do
            if x:IsA("BodyAngularVelocity") or x:IsA("BodyForce") or x:IsA("BodyGyro") or
               x:IsA("BodyPosition") or x:IsA("BodyThrust") or x:IsA("BodyVelocity") then
                x:Destroy()
            end
        end
        if v:FindFirstChild("Torque") then
            pcall(function() v.Torque:Destroy() end)
        end
        local bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.Parent = v
        bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        local bodyGyro = nil
        if _G.globalFixedMode then
            bodyGyro = Instance.new("BodyGyro")
            bodyGyro.Parent = v
            bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            bodyGyro.P = 1000
            bodyGyro.D = 100
            bodyGyro.CFrame = v.CFrame
        end
        _G.globalProcessedParts[v] = {
            bodyVelocity = bodyVelocity,
            bodyGyro = bodyGyro
        }
    end
end

local function GlobalProcessAllParts()
    for _, v in ipairs(Workspace:GetDescendants()) do
        GlobalProcessPart(v)
    end
    if _G.globalUpdateConnection then
        _G.globalUpdateConnection:Disconnect()
    end
    _G.globalUpdateConnection = RunService.Heartbeat:Connect(function()
        for part, data in pairs(_G.globalProcessedParts) do
            if data.bodyVelocity and data.bodyVelocity.Parent then
                if _G.globalMoveDirectionType then
                    data.bodyVelocity.Velocity = GlobalCalculateMoveDirection() * _G.globalFloatSpeed
                else
                    data.bodyVelocity.Velocity = Vector3.new(0, 0, 0)
                end
            end
        end
    end)
end

local function GlobalCleanupParts()
    if _G.globalUpdateConnection then
        _G.globalUpdateConnection:Disconnect()
        _G.globalUpdateConnection = nil
    end
    if _G.globalDescendantConnection then
        _G.globalDescendantConnection:Disconnect()
        _G.globalDescendantConnection = nil
    end
    for part, data in pairs(_G.globalProcessedParts) do
        if data.bodyVelocity and data.bodyVelocity.Parent then
            data.bodyVelocity:Destroy()
        end
        if data.bodyGyro and data.bodyGyro.Parent then
            data.bodyGyro:Destroy()
        end
    end
    _G.globalProcessedParts = {}
    _G.globalActiveFlips = {}
    _G.globalFlipAngularVelocities = {}
    _G.globalCurrentMoveDirection = nil
    _G.globalMoveDirectionType = nil
end

local function GlobalMoveDirection(direction)
    _G.globalMoveDirectionType = direction
    _G.globalCurrentMoveDirection = direction
    for part, data in pairs(_G.globalProcessedParts) do
        if part and part.Parent then
            part.Anchored = false
            if not data.bodyVelocity or not data.bodyVelocity.Parent then
                local bodyVelocity = Instance.new("BodyVelocity")
                bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                bodyVelocity.Parent = part
                data.bodyVelocity = bodyVelocity
            end
            data.bodyVelocity.Velocity = GlobalCalculateMoveDirection() * _G.globalFloatSpeed
            if _G.globalFixedMode then
                if not data.bodyGyro or not data.bodyGyro.Parent then
                    local bodyGyro = Instance.new("BodyGyro")
                    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                    bodyGyro.P = 1000
                    bodyGyro.D = 100
                    bodyGyro.CFrame = part.CFrame
                    bodyGyro.Parent = part
                    data.bodyGyro = bodyGyro
                end
            end
        end
    end
end

local function GlobalStopMovement()
    _G.globalMoveDirectionType = nil
    _G.globalCurrentMoveDirection = nil
    for part, data in pairs(_G.globalProcessedParts) do
        if data.bodyVelocity and data.bodyVelocity.Parent then
            data.bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    end
end

local function GlobalToggleFixedMode()
    _G.globalFixedMode = not _G.globalFixedMode
    if _G.globalFixedMode then
        for part, data in pairs(_G.globalProcessedParts) do
            if part and part.Parent then
                if not data.bodyGyro or not data.bodyGyro.Parent then
                    local bodyGyro = Instance.new("BodyGyro")
                    bodyGyro.Parent = part
                    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                    bodyGyro.P = 1000
                    bodyGyro.D = 100
                    bodyGyro.CFrame = part.CFrame
                    data.bodyGyro = bodyGyro
                else
                    data.bodyGyro.CFrame = part.CFrame
                end
            end
        end
    else
        for part, data in pairs(_G.globalProcessedParts) do
            if data.bodyGyro and data.bodyGyro.Parent then
                data.bodyGyro:Destroy()
                data.bodyGyro = nil
            end
        end
    end
    return _G.globalFixedMode
end

local function GlobalApplyFlip(axis, angleDegrees)
    local camera = Workspace.CurrentCamera
    if not camera then return end
    local rightVector = camera.CFrame.RightVector
    local upVector = camera.CFrame.UpVector
    local angleRadians = math.rad(angleDegrees) * _G.rotationSpeed
    for part, data in pairs(_G.globalProcessedParts) do
        if part and part.Parent then
            if _G.globalActiveFlips[part] then
                if _G.globalFlipAngularVelocities[part] then
                    _G.globalFlipAngularVelocities[part]:Destroy()
                    _G.globalFlipAngularVelocities[part] = nil
                end
                _G.globalActiveFlips[part] = nil
            end
            if data.bodyGyro and data.bodyGyro.Parent then
                data.savedBodyGyro = data.bodyGyro
                data.bodyGyro.Parent = nil
                data.bodyGyro = nil
            end
            for _, child in ipairs(part:GetChildren()) do
                if child:IsA("BodyAngularVelocity") then
                    child:Destroy()
                end
            end
            local angularVelocity = Vector3.new(0, 0, 0)
            if axis == "X" then
                angularVelocity = rightVector * angleRadians
            elseif axis == "Y" then
                angularVelocity = upVector * angleRadians
            elseif axis == "Z" then
                angularVelocity = camera.CFrame.LookVector * angleRadians
            end
            local bodyAngularVelocity = Instance.new("BodyAngularVelocity")
            bodyAngularVelocity.AngularVelocity = angularVelocity
            bodyAngularVelocity.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            bodyAngularVelocity.Parent = part
            _G.globalFlipAngularVelocities[part] = bodyAngularVelocity
            _G.globalActiveFlips[part] = {
                axis = axis,
                targetAngle = math.rad(angleDegrees),
                startTime = tick(),
                angularVelocity = bodyAngularVelocity
            }
        end
    end
end

function EnterGlobalMode()
    if _G.spaceshipMode then
        ExitSpaceshipMode()
    end
    if _G.isFollowing then
        _G.isFollowing = false
        StopPart()
        removeHighlight()
        _G.selectedPart = nil
    end
    for part, _ in pairs(_G.fixedParts) do
        if part and part.Parent then
            part.Anchored = false
        end
    end
    _G.fixedParts = {}
    _G.isFixed = false
    if guiRefs.controlPanel then
        guiRefs.controlPanel.Visible = false
    end
    _G.savedSelectMode = _G.selectModeActive
    _G.selectModeActive = false
    if guiRefs.selectModeButton then
        guiRefs.selectModeButton.Text = "选择模式: 关闭"
        guiRefs.selectModeButton.TextColor3 = Color3.fromRGB(220, 80, 80)
    end
    _G.globalMode = true
    _G.globalMoveDirectionType = nil
    _G.globalCurrentMoveDirection = nil
    GlobalProcessAllParts()
    _G.globalDescendantConnection = Workspace.DescendantAdded:Connect(function(v)
        if _G.globalMode then
            GlobalProcessPart(v)
        end
    end)
    if guiRefs.toggleGlobalModeUI then
        guiRefs.toggleGlobalModeUI.Visible = true
        guiRefs.toggleGlobalModeUI.Text = "隐藏全局模式UI"
    end
end

function ExitGlobalMode()
    _G.globalMode = false
    GlobalCleanupParts()
    _G.selectModeActive = _G.savedSelectMode or false
    if guiRefs.selectModeButton then
        if _G.selectModeActive then
            guiRefs.selectModeButton.Text = "选择模式: 开启"
            guiRefs.selectModeButton.TextColor3 = Color3.fromRGB(80, 200, 80)
        else
            guiRefs.selectModeButton.Text = "选择模式: 关闭"
            guiRefs.selectModeButton.TextColor3 = Color3.fromRGB(220, 80, 80)
        end
    end
    if guiRefs.toggleGlobalModeUI then
        guiRefs.toggleGlobalModeUI.Visible = false
        guiRefs.toggleGlobalModeUI.Text = "隐藏全局模式UI"
    end
end

