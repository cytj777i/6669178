local function SetupFlipDetection()
    RunService.Heartbeat:Connect(function()
        local currentTime = tick()
        for part, flipData in pairs(_G.activeFlips) do
            if part and part.Parent and flipData.angularVelocity and flipData.angularVelocity.Parent then
                local elapsedTime = currentTime - flipData.startTime
                local angVel = flipData.angularVelocity.AngularVelocity
                local expectedAngle = angVel.Magnitude * elapsedTime
                if expectedAngle >= math.abs(flipData.targetAngle) then
                    flipData.angularVelocity.AngularVelocity = Vector3.new(0, 0, 0)
                    _G.activeFlips[part] = nil
                    _G.flipAngularVelocities[part] = nil
                end
            else
                _G.activeFlips[part] = nil
                _G.flipAngularVelocities[part] = nil
            end
        end
        for part, flipData in pairs(_G.globalActiveFlips) do
            if part and part.Parent and flipData.angularVelocity and flipData.angularVelocity.Parent then
                local elapsedTime = currentTime - flipData.startTime
                local angVel = flipData.angularVelocity.AngularVelocity
                local expectedAngle = angVel.Magnitude * elapsedTime
                if expectedAngle >= math.abs(flipData.targetAngle) then
                    flipData.angularVelocity.AngularVelocity = Vector3.new(0, 0, 0)
                    if _G.globalProcessedParts[part] and _G.globalProcessedParts[part].savedBodyGyro then
                        local bg = _G.globalProcessedParts[part].savedBodyGyro
                        if bg then
                            bg.Parent = part
                            bg.CFrame = part.CFrame
                            _G.globalProcessedParts[part].bodyGyro = bg
                            _G.globalProcessedParts[part].savedBodyGyro = nil
                        end
                    end
                    _G.globalActiveFlips[part] = nil
                    _G.globalFlipAngularVelocities[part] = nil
                end
            else
                if _G.globalProcessedParts[part] and _G.globalProcessedParts[part].savedBodyGyro then
                    local bg = _G.globalProcessedParts[part].savedBodyGyro
                    if bg then
                        bg.Parent = part
                        _G.globalProcessedParts[part].bodyGyro = bg
                    end
                    _G.globalProcessedParts[part].savedBodyGyro = nil
                end
                _G.globalActiveFlips[part] = nil
                _G.globalFlipAngularVelocities[part] = nil
            end
        end
    end)
end
SetupFlipDetection()

