            _G.isFollowing = false
            if not _G.isFixed then
                StopPart()
                removeHighlight()
                _G.selectedPart = nil
            end
        end
        if _G.globalMode then
            ExitGlobalMode()
        end
        if _G.spaceshipMode then
            ExitSpaceshipMode()
        end
    end)
